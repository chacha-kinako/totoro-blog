---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				max-width: 740px;
				margin: auto;
				padding: 2em 1em 5em;
			}

			/* パンくず風ナビ */
			.breadcrumb {
				font-size: 0.82em;
				color: var(--text-muted);
				margin-bottom: 1.5em;
				display: flex;
				align-items: center;
				gap: 0.4em;
			}
			.breadcrumb a { color: var(--green); }
			.breadcrumb::before { content: '🌿'; margin-right: 0.2em; }

			/* ヒーロー画像 */
			.hero-image {
				margin-bottom: 1.8em;
				border-radius: 18px;
				overflow: hidden;
				box-shadow: var(--shadow-md);
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 0;
			}

			/* 記事ヘッダー */
			.article-header {
				background: #fff;
				border-radius: 18px;
				border: 1px solid var(--border);
				box-shadow: var(--shadow-sm);
				overflow: hidden;
				margin-bottom: 1.5em;
			}
			.article-header__bar {
				height: 8px;
				background: linear-gradient(90deg, var(--green-dark) 0%, var(--green) 50%, var(--acorn) 100%);
			}
			.article-header__body {
				padding: 1.8em 2em;
			}
			.article-header__meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.82em;
				color: var(--green-light);
				font-weight: 600;
				margin-bottom: 0.7em;
			}
			.article-header__meta::before { content: '🌱'; }
			.article-header h1 {
				font-size: 1.65em;
				line-height: 1.4;
				margin: 0 0 0.6em;
				color: var(--text);
			}
			.article-header__desc {
				font-size: 0.92em;
				color: var(--text-muted);
				line-height: 1.7;
				margin: 0;
				padding: 0.8em;
				background: var(--cream);
				border-radius: 10px;
				border-left: 3px solid var(--green-light);
			}

			/* 本文 */
			.prose {
				background: #fff;
				border-radius: 18px;
				border: 1px solid var(--border);
				box-shadow: var(--shadow-sm);
				padding: 2em 2.2em;
				font-size: 1em;
				color: var(--text);
			}

			/* フッター装飾 */
			.article-footer {
				margin-top: 2em;
				text-align: center;
				color: var(--text-muted);
				font-size: 0.85em;
				padding: 1.2em;
				background: var(--green-pale);
				border-radius: 12px;
			}
			.article-footer::before { content: '🌳　🍃　🌰　🍃　🌳'; display: block; font-size: 1.1em; margin-bottom: 0.3em; letter-spacing: 0.3em; }

			@media (max-width: 720px) {
				main { padding: 1em 0.8em 3em; }
				.article-header__body { padding: 1.3em 1.2em; }
				.article-header h1 { font-size: 1.3em; }
				.prose { padding: 1.4em 1.2em; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href="/blog">記事一覧</a>
				<span>›</span>
				<span>{title}</span>
			</nav>

			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}

				<div class="article-header">
					<div class="article-header__bar" />
					<div class="article-header__body">
						<div class="article-header__meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span>（更新: <FormattedDate date={updatedDate} />）</span>
							)}
						</div>
						<h1>{title}</h1>
						{description && (
							<p class="article-header__desc">{description}</p>
						)}
					</div>
				</div>

				<div class="prose">
					<slot />
				</div>

				<div class="article-footer">
					最後まで読んでくれてありがとう！また遊びにきてね。
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
