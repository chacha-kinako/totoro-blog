---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ヒーロー写真帯 */
			.blog-hero {
				width: 100vw;
				margin-left: calc(50% - 50vw);
				height: 340px;
				position: relative;
				overflow: hidden;
				margin-bottom: 2.5em;
			}
			.blog-hero__img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center 30%;
				display: block;
				border-radius: 0;
			}
			.blog-hero__overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(20, 45, 28, 0.18) 0%,
					rgba(20, 45, 28, 0.52) 100%
				);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 1em;
			}
			.blog-hero__title {
				font-family: 'Kaisei Decol', 'Hiragino Mincho ProN', 'Yu Mincho', serif;
				color: #fff;
				font-size: 2.2em;
				font-weight: 700;
				margin: 0 0 0.3em;
				text-shadow:
					0 2px 12px rgba(20, 60, 30, 0.7),
					0 0 40px rgba(20, 60, 30, 0.4);
				letter-spacing: 0.1em;
				line-height: 1.3;
			}
			.blog-hero__desc {
				font-family: 'Kaisei Decol', 'Hiragino Mincho ProN', serif;
				color: rgba(255,255,255,0.92);
				font-size: 0.95em;
				margin: 0;
				letter-spacing: 0.12em;
				text-shadow: 0 1px 6px rgba(20, 60, 30, 0.7);
			}
			@media (max-width: 600px) {
				.blog-hero { height: 220px; }
				.blog-hero__title { font-size: 1.5em; }
			}

			/* グリッド */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.4rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			/* カード */
			.post-card {
				background: #fff;
				border-radius: 16px;
				border: 1px solid var(--border);
				box-shadow: var(--shadow-sm);
				transition: transform 0.22s ease, box-shadow 0.22s ease;
				overflow: hidden;
			}
			.post-card:hover {
				transform: translateY(-5px);
				box-shadow: var(--shadow-hover);
			}
			.post-card a {
				display: block;
				text-decoration: none;
				color: inherit;
				height: 100%;
			}

			/* カード上部のカラーバー */
			.post-card__bar {
				height: 6px;
				background: linear-gradient(90deg, var(--green) 0%, var(--acorn) 100%);
			}

			.post-card__body {
				padding: 1.3em 1.4em 1.4em;
			}

			.post-card__date {
				font-size: 0.78em;
				color: var(--green-light);
				font-weight: 600;
				margin-bottom: 0.5em;
				display: flex;
				align-items: center;
				gap: 0.3em;
			}
			.post-card__date::before {
				content: '';
			}

			.post-card__title {
				font-size: 0.97em;
				font-weight: 700;
				color: var(--text);
				line-height: 1.45;
				margin: 0 0 0.6em;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.post-card__desc {
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.6;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* セクションタイトル */
			.section-label {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 1em;
				font-weight: 700;
				color: var(--green-dark);
				margin-bottom: 1.2em;
			}
			.section-label::before { content: ''; }
			.section-label::after  {
				content: '';
				flex: 1;
				height: 2px;
				background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
				border-radius: 2px;
			}

			@media (max-width: 600px) {
				.post-grid { grid-template-columns: 1fr; }
				.blog-hero { padding: 2em 1.2em; }
				.blog-hero__title { font-size: 1.2em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ヒーロー写真帯 -->
			<div class="blog-hero">
				<img class="blog-hero__img" src="/hero-bg.jpg" alt="ジブリグッズでいっぱいのお部屋" />
				<div class="blog-hero__overlay">
					<p class="blog-hero__title">トトロとジブリの森から</p>
					<p class="blog-hero__desc">グッズ・暮らし・お気に入りをのんびり発信中</p>
				</div>
			</div>

			<!-- 記事一覧 -->
			<p class="section-label">記事一覧</p>
			<ul class="post-grid">
				{
					posts.map((post) => (
						<li class="post-card">
							<a href={`/blog/${post.id}/`}>
								<div class="post-card__bar" />
								<div class="post-card__body">
									<p class="post-card__date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="post-card__title">{post.data.title}</h2>
									{post.data.description && (
										<p class="post-card__desc">{post.data.description}</p>
									)}
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
