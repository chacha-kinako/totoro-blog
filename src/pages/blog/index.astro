---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ヘッダーバナー */
			.blog-hero {
				background: linear-gradient(135deg, #2d5a3d 0%, #4a7a5a 50%, #6a9a72 100%);
				border-radius: 20px;
				padding: 2.5em 2em;
				margin-bottom: 2.5em;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.blog-hero::before {
				content: '🌳　🍃　🌰　🍂　🌿　🌱　🍃　🌳';
				position: absolute;
				top: 0.5em;
				left: 0;
				right: 0;
				font-size: 1.1em;
				opacity: 0.25;
				letter-spacing: 0.5em;
				white-space: nowrap;
				overflow: hidden;
			}
			.blog-hero::after {
				content: '🌿　🌰　🍃　🌳　🍂　🌱　🍃　🌰';
				position: absolute;
				bottom: 0.5em;
				left: 0;
				right: 0;
				font-size: 1.1em;
				opacity: 0.25;
				letter-spacing: 0.5em;
				white-space: nowrap;
				overflow: hidden;
			}
			.blog-hero__title {
				color: #fff;
				font-size: 1.6em;
				font-weight: 800;
				margin: 0 0 0.3em;
				text-shadow: 0 1px 4px rgba(0,0,0,0.2);
			}
			.blog-hero__desc {
				color: rgba(255,255,255,0.85);
				font-size: 0.9em;
				margin: 0;
			}

			/* グリッド */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.4rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			/* カード */
			.post-card {
				background: #fff;
				border-radius: 16px;
				border: 1px solid var(--border);
				box-shadow: var(--shadow-sm);
				transition: transform 0.22s ease, box-shadow 0.22s ease;
				overflow: hidden;
			}
			.post-card:hover {
				transform: translateY(-5px);
				box-shadow: var(--shadow-hover);
			}
			.post-card a {
				display: block;
				text-decoration: none;
				color: inherit;
				height: 100%;
			}

			/* カード上部のカラーバー */
			.post-card__bar {
				height: 6px;
				background: linear-gradient(90deg, var(--green) 0%, var(--acorn) 100%);
			}

			.post-card__body {
				padding: 1.3em 1.4em 1.4em;
			}

			.post-card__date {
				font-size: 0.78em;
				color: var(--green-light);
				font-weight: 600;
				margin-bottom: 0.5em;
				display: flex;
				align-items: center;
				gap: 0.3em;
			}
			.post-card__date::before {
				content: '🌱';
				font-size: 0.9em;
			}

			.post-card__title {
				font-size: 0.97em;
				font-weight: 700;
				color: var(--text);
				line-height: 1.45;
				margin: 0 0 0.6em;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.post-card__desc {
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.6;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* セクションタイトル */
			.section-label {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 1em;
				font-weight: 700;
				color: var(--green-dark);
				margin-bottom: 1.2em;
			}
			.section-label::before { content: '🍂'; }
			.section-label::after  {
				content: '';
				flex: 1;
				height: 2px;
				background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
				border-radius: 2px;
			}

			@media (max-width: 600px) {
				.post-grid { grid-template-columns: 1fr; }
				.blog-hero { padding: 2em 1.2em; }
				.blog-hero__title { font-size: 1.2em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ヘッダーバナー -->
			<div class="blog-hero">
				<p class="blog-hero__title">🌰 トトロとジブリの森から</p>
				<p class="blog-hero__desc">グッズ・暮らし・お気に入りをのんびり発信中</p>
			</div>

			<!-- 記事一覧 -->
			<p class="section-label">記事一覧</p>
			<ul class="post-grid">
				{
					posts.map((post) => (
						<li class="post-card">
							<a href={`/blog/${post.id}/`}>
								<div class="post-card__bar" />
								<div class="post-card__body">
									<p class="post-card__date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="post-card__title">{post.data.title}</h2>
									{post.data.description && (
										<p class="post-card__desc">{post.data.description}</p>
									)}
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
