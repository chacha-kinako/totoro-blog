---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="site-header__inner">
		<a href="/" class="site-header__logo">{SITE_TITLE}</a>
		<nav class="site-header__nav">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">記事一覧</HeaderLink>
			<HeaderLink href="/about">このブログについて</HeaderLink>
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: #fff;
		border-bottom: 3px solid var(--green);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.site-header__inner {
		max-width: 900px;
		margin: auto;
		padding: 0 1.5em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
	}
	.site-header__logo {
		font-size: 1.1em;
		font-weight: 800;
		color: var(--green-dark);
		text-decoration: none;
		letter-spacing: 0.02em;
	}
	.site-header__logo:hover {
		color: var(--green);
		text-decoration: none;
	}
	.site-header__nav {
		display: flex;
		gap: 0.2em;
	}
	.site-header__nav a {
		font-size: 0.88em;
		font-weight: 600;
		color: var(--text-muted);
		padding: 0.4em 0.8em;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}
	.site-header__nav a:hover,
	.site-header__nav a.active {
		background: var(--green-pale);
		color: var(--green-dark);
		text-decoration: none;
	}
	@media (max-width: 600px) {
		.site-header__inner { padding: 0 1em; }
		.site-header__nav a { padding: 0.4em 0.5em; font-size: 0.82em; }
		.site-header__logo { font-size: 0.95em; }
	}
</style>
