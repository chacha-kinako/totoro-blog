---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="site-header__inner">
		<a href="/" class="site-header__logo">{SITE_TITLE}</a>
		<nav class="site-header__nav">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">記事一覧</HeaderLink>
			<HeaderLink href="/about">プロフィール</HeaderLink>
			<a href="/#latest" class="nav-anchor">最新の記事</a>
			<a href="/#popular" class="nav-anchor">人気の記事</a>
			<a href="/#categories" class="nav-anchor">カテゴリ</a>
			<a href="/rss.xml" class="nav-anchor nav-anchor--rss" target="_blank" rel="noopener">RSS</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: #fff;
		border-bottom: 1px solid var(--beige-light);
		position: sticky;
		top: 0;
		z-index: 100;
		box-shadow: 0 1px 10px rgba(180, 100, 50, 0.07);
	}
	.site-header__inner {
		max-width: 960px;
		margin: auto;
		padding: 0 1.5em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
		gap: 1em;
	}
	.site-header__logo {
		font-family: 'Kaisei Decol', 'Hiragino Mincho ProN', serif;
		font-size: 0.95em;
		font-weight: 700;
		color: var(--orange-dark);
		text-decoration: none;
		letter-spacing: 0.05em;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.site-header__logo:hover { color: var(--orange); text-decoration: none; }

	.site-header__nav {
		display: flex;
		align-items: center;
		gap: 0.05em;
		flex-wrap: nowrap;
		overflow-x: auto;
	}
	.site-header__nav a {
		font-size: 0.8em;
		font-weight: 500;
		color: var(--text-muted);
		padding: 0.4em 0.65em;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
		white-space: nowrap;
	}
	.site-header__nav a:hover,
	.site-header__nav a.active {
		background: var(--orange-pale);
		color: var(--orange-dark);
		text-decoration: none;
	}
	.nav-anchor--rss {
		color: var(--green-dark) !important;
		border: 1px solid var(--green-light);
		border-radius: 50px !important;
		padding: 0.3em 0.75em !important;
	}
	.nav-anchor--rss:hover {
		background: var(--green-pale) !important;
		color: var(--green-dark) !important;
	}

	@media (max-width: 680px) {
		.site-header__inner { padding: 0 0.8em; height: 52px; }
		.site-header__logo { font-size: 0.85em; }
		.site-header__nav a { padding: 0.3em 0.45em; font-size: 0.73em; }
	}
</style>
